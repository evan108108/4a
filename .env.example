# 4A — Cloudflare deploy credentials (template)
#
# Copy this file to .env and fill in the values from your Cloudflare dashboard.
# .env is gitignored; never commit your real values.
#
# Two auth modes are supported:
#
#   1. Scoped API token (preferred):
#        CLOUDFLARE_API_TOKEN=<token from My Profile → API Tokens>
#        CLOUDFLARE_ACCOUNT_ID=<hex from Workers & Pages → Overview sidebar>
#
#   2. Global API Key (legacy, full-account access):
#        CLOUDFLARE_EMAIL=<your CF login email>
#        CLOUDFLARE_API_KEY=<key from My Profile → API Keys>
#        CLOUDFLARE_ACCOUNT_ID=<hex from Workers & Pages → Overview sidebar>
#
# wrangler reads these env vars and prefers them over any OAuth login in
# ~/.config/.wrangler/. That isolation is why this project doesn't run
# `wrangler login`.

# CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# GitHub OAuth (Phase 2 — custodial publishing)
# Register an OAuth app at https://github.com/settings/developers
# Set Authorization callback URL to https://api.4a4.ai/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# JWT signing key (Phase 2 — generate via: openssl rand -base64 32)
# Set via: wrangler secret put JWT_SIGNING_KEY
# Do NOT put real values in .env — use wrangler secrets for production
JWT_SIGNING_KEY=

# AWS KMS (Phase 2 — see docs/phase-2-aws-setup.md)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
KMS_DERIVATION_KEY_ID=
